{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "bonkergames.com"}],
      "destination": "https://www.bonkergames.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "2d-game-beta.vercel.app"}],
      "destination": "https://www.bonkergames.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/game/bonker-survival", "destination": "/games/bonker-survival/play.html" },
    { "source": "/game/bonker-chess",    "destination": "/games/bonker-chess/play.html" },
    { "source": "/game/tic-tac-toe",     "destination": "/games/tic-tac-toe-online/play.html" },
    { "source": "/game/snake",           "destination": "/games/snake/play.html" },
    { "source": "/game/2048",            "destination": "/games/2048/play.html" },
    { "source": "/game/breakout",        "destination": "/games/breakout/play.html" },
    { "source": "/game/flappy-bird",     "destination": "/games/flappy-bird/play.html" },
    { "source": "/game/tetris",          "destination": "/games/tetris/play.html" },
    { "source": "/game/minesweeper",     "destination": "/games/minesweeper/play.html" },
    { "source": "/game/memory-match",    "destination": "/games/memory-match/play.html" },
    { "source": "/game/simon-says",      "destination": "/games/simon-says/play.html" },
    { "source": "/game/connect-four",    "destination": "/games/connect-four/play.html" },
    { "source": "/game/pong",            "destination": "/games/pong/play.html" }
  ]
}
